@startuml Use_Case

skinparam backgroundColor #FFFFFF
skinparam usecase {
  BackgroundColor #D6E8F7
  BorderColor #1A3A5C
  FontName Arial
  FontSize 12
  FontColor #1A3A5C
}
skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #1A3A5C
  FontColor #1A3A5C
  FontName Arial
  FontSize 12
}
skinparam ArrowColor #1A3A5C
skinparam ArrowThickness 1.5
skinparam ArrowFontName Arial
skinparam ArrowFontSize 11
skinparam shadowing false
skinparam packageStyle rectangle
skinparam package {
  BackgroundColor #F0F6FC
  BorderColor #2563A8
  FontName Arial
  FontSize 12
  FontColor #2563A8
  FontStyle bold
}
skinparam linetype ortho

title Diagramme de Cas d\'Utilisation\nSystème de Gestion RH Intelligent

' ── Acteurs (placés en haut) ──────────────
actor "Employé" as EMP
actor "Responsable RH" as RH
actor "Administrateur" as ADMIN

' ── Système ──────────────────────────────
rectangle "Système RH Intelligent" {

  package "Authentification" {
    usecase "Se connecter (JWT)" as UC1
    usecase "Gérer son profil" as UC2
  }

  package "Gestion RH" {
    usecase "Gérer les employés" as UC3
    usecase "Gérer les congés" as UC4
    usecase "Gérer les présences" as UC5
    usecase "Gérer la paie" as UC6
  }

  package "Intelligence Artificielle" {
    usecase "Détecter les anomalies\n(Isolation Forest)" as UC7
    usecase "Segmenter les profils\n(K-Means)" as UC8
  }

  package "Analyse Documentaire" {
    usecase "Uploader un document" as UC9
    usecase "Extraire le texte (OCR)" as UC10
  }

  package "Administration" {
    usecase "Gérer les utilisateurs\net les rôles" as UC11
  }
}

' ── Relations Employé ─────────────────────
EMP --> UC1
EMP --> UC2
EMP --> UC4
EMP --> UC5
EMP --> UC9

' ── Relations RH ─────────────────────────
RH --> UC1
RH --> UC3
RH --> UC4
RH --> UC5
RH --> UC6
RH --> UC7
RH --> UC9

' ── Relations Admin ──────────────────────
ADMIN --> UC1
ADMIN --> UC11
ADMIN --> UC3

' ── Include / Extend ─────────────────────
UC9 ..> UC10 : <<include>>
UC7 ..> UC8  : <<extend>>

@enduml
